{
    "name": "contabilidade/iddrs",
    "description": "Ferramentas da contabilidade",
    "type": "project",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "App\\Command\\": "./Command/"
        }
    },
    "authors": [
        {
            "name": "Everton da Rosa",
            "email": "everton3x@gmail.com"
        }
    ],
    "require": {
        "ulrichsg/getopt-php": "^4.0",
        "monolog/monolog": "^3.10",
        "vlucas/phpdotenv": "^5.6",
        "bramus/monolog-colored-line-formatter": "~3.1",
        "ext-ds": "^1.6",
        "everton3x/autoload-files-plugin": "^1.0",
        "coduo/php-humanizer": "^5.0",
        "twig/twig": "^3.24",
        "twig/intl-extra": "^3.24"
    },
    "config": {
        "allow-plugins": {
            "everton3x/autoload-files-plugin": true
        }
    },
    "extra": {
        "autoload-files-from": [
            "./app/"
        ]
    },
    "require-dev": {
        "nunomaduro/collision": "^8.9"
    }
}
